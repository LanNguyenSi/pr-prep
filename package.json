{
  "name": "pr-prep",
  "version": "0.1.0",
  "description": "CLI tool to prepare pull requests with pre-flight checks and auto-generated descriptions",
  "type": "module",
  "bin": {
    "pr-prep": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
    "pr",
    "pull-request",
    "git",
    "github",
    "cli",
    "automation"
  ],
  "author": "Lava",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "ora": "^8.1.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "eslint": "^9.18.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
